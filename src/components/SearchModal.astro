---
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const searchIndex = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  date: post.data.date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }),
  tags: post.data.tags ?? [],
  url: `/posts/${post.id}`,
}));
---

<script type="application/json" id="search-data" set:html={JSON.stringify(searchIndex)} />

<div
  id="search-modal"
  class="hidden fixed inset-0 z-50"
  role="dialog"
  aria-modal="true"
  aria-label="Search posts"
>
  <div id="search-backdrop" class="absolute inset-0 bg-black/50"></div>
  <div class="relative flex items-start justify-center pt-[15vh] px-4">
    <div class="w-full max-w-lg bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-200">
        <svg class="w-5 h-5 text-gray-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search posts..."
          class="w-full bg-transparent text-gray-900 placeholder-gray-400 focus:outline-none"
          autocomplete="off"
        />
        <kbd class="shrink-0 text-xs text-gray-400 border border-gray-200 rounded px-1.5 py-0.5 font-sans">Esc</kbd>
      </div>
      <ul id="search-results" class="max-h-80 overflow-y-auto divide-y divide-gray-100"></ul>
      <div id="search-empty" class="hidden px-4 py-8 text-center text-sm text-gray-400">
        No results found.
      </div>
      <div id="search-hint" class="hidden border-t border-gray-100 px-4 py-2 text-xs text-gray-400">
        <span class="inline-flex items-center gap-1"><kbd class="border border-gray-200 rounded px-1 py-0.5 font-sans">↑↓</kbd> navigate</span>
        <span class="ml-3 inline-flex items-center gap-1"><kbd class="border border-gray-200 rounded px-1 py-0.5 font-sans">↵</kbd> open</span>
        <span class="ml-3 inline-flex items-center gap-1"><kbd class="border border-gray-200 rounded px-1 py-0.5 font-sans">esc</kbd> close</span>
      </div>
    </div>
  </div>
</div>

<script>
  function initSearch() {
    const dataEl = document.getElementById("search-data");
    if (!dataEl?.textContent) return;

    const posts: {
      title: string;
      description: string;
      date: string;
      tags: string[];
      url: string;
    }[] = JSON.parse(dataEl.textContent);

    const modal = document.getElementById("search-modal")!;
    const backdrop = document.getElementById("search-backdrop")!;
    const input = document.getElementById("search-input") as HTMLInputElement;
    const resultsList = document.getElementById("search-results")!;
    const emptyEl = document.getElementById("search-empty")!;
    const hintEl = document.getElementById("search-hint")!;

    let selectedIndex = -1;
    let filtered: typeof posts = [];

    function open() {
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      input.value = "";
      search("");
      input.focus();
    }

    function close() {
      modal.classList.add("hidden");
      document.body.style.overflow = "";
    }

    function search(query: string) {
      const terms = query.toLowerCase().trim().split(/\s+/).filter(Boolean);

      if (terms.length === 0) {
        filtered = posts;
      } else {
        filtered = posts.filter((post) => {
          const haystack = [post.title, post.description, ...post.tags]
            .join(" ")
            .toLowerCase();
          return terms.every((term) => haystack.includes(term));
        });
      }

      selectedIndex = filtered.length > 0 ? 0 : -1;
      render();
    }

    function render() {
      resultsList.innerHTML = "";

      if (filtered.length === 0) {
        emptyEl.classList.remove("hidden");
        hintEl.classList.add("hidden");
        return;
      }

      emptyEl.classList.add("hidden");
      hintEl.classList.remove("hidden");

      filtered.forEach((post, i) => {
        const li = document.createElement("li");
        li.innerHTML = `
          <a href="${post.url}" class="block px-4 py-3 hover:bg-gray-50 transition-colors">
            <div class="font-medium text-gray-900">${escapeHtml(post.title)}</div>
            <div class="text-sm text-gray-500 mt-0.5">${escapeHtml(post.date)}</div>
            <div class="text-sm text-gray-600 mt-0.5 truncate">${escapeHtml(post.description)}</div>
          </a>
        `;
        if (i === selectedIndex) {
          li.firstElementChild!.classList.add("bg-gray-50");
        }
        li.setAttribute("data-index", String(i));
        resultsList.appendChild(li);
      });
    }

    function setSelected(index: number) {
      if (filtered.length === 0) return;
      selectedIndex = Math.max(0, Math.min(index, filtered.length - 1));
      const items = resultsList.querySelectorAll("li");
      items.forEach((li, i) => {
        const link = li.firstElementChild!;
        if (i === selectedIndex) {
          link.classList.add("bg-gray-50");
          li.scrollIntoView({ block: "nearest" });
        } else {
          link.classList.remove("bg-gray-50");
        }
      });
    }

    function escapeHtml(str: string) {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }

    // Global keyboard shortcut
    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (modal.classList.contains("hidden")) {
          open();
        } else {
          close();
        }
      }
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        close();
      }
    });

    // Input search
    input.addEventListener("input", () => {
      search(input.value);
    });

    // Keyboard navigation in results
    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setSelected(selectedIndex + 1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setSelected(selectedIndex - 1);
      } else if (e.key === "Enter" && selectedIndex >= 0 && filtered[selectedIndex]) {
        e.preventDefault();
        window.location.href = filtered[selectedIndex].url;
      }
    });

    // Backdrop click
    backdrop.addEventListener("click", close);

    // Trigger button
    document.getElementById("search-trigger")?.addEventListener("click", open);
  }

  initSearch();
  document.addEventListener("astro:after-swap", initSearch);
</script>
